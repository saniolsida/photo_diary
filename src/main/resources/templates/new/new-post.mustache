<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>새 일기 쓰기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">새로운 순간 기록하기</h4>
                </div>
                <div class="card-body">
                    <form action="/post/create" method="post">
                        <div class="mb-3">
                            <label class="form-label">작성자</label>
                            <input type="text" name="author" class="form-control" placeholder="이름을 입력하세요" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">제목</label>
                            <input type="text" name="title" class="form-control" placeholder="제목을 입력하세요" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">이미지 URL</label>
                            <input type="text" name="imageUrl" class="form-control" placeholder="https://..." required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">내용</label>
                            <textarea name="content" class="form-control" rows="5" placeholder="오늘의 이야기를 들려주세요" required></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/" class="btn btn-secondary">취소</a>
                            <button type="submit" class="btn btn-primary">저장하기</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>