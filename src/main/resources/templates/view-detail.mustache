<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>{{post.title}} - 상세보기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/index.css">

</head>
<body class="bg-light">


<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold text-primary" href="/">
            <i class="bi bi-camera-fill"></i> Photo Diary
        </a>
    </div>
</nav>

<div class="container py-4">
    {{#post}}
        <div class="row justify-content-center">
            <div class="col-lg-8 detail-container">
                <h1 class="fw-bold mb-3">{{title}}</h1>
                <p class="text-muted mb-4 small">
                    <i class="bi bi-person"></i> {{author}} |
                    <i class="bi bi-calendar3"></i> {{formattedDate}}
                </p>

                <div class="text-center mb-4">
                    <img src="{{post.imageUrl}}" class="detail-img shadow-sm rounded" alt="Post Image">
                </div>

                <div class="content-area fs-5 mb-5">
                    {{content}}
                </div>

                <hr class="my-4 opacity-25">

                <div class="d-flex justify-content-between align-items-center">
                    <a href="/" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-list"></i> 목록으로
                    </a>
                    <div>
                        <a href="/post/edit/{{id}}" class="btn btn-outline-primary me-2 px-4">
                            <i class="bi bi-pencil-square"></i> 수정
                        </a>
                        <a href="/post/delete/{{id}}" class="btn btn-outline-danger px-4"
                           onclick="return confirm('정말 삭제하시겠습니까?')">
                            <i class="bi bi-trash"></i> 삭제
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {{/post}}
</div>

<footer class="mt-5 py-4 text-center text-muted small">
    © 2026 <strong>Songsan</strong>. All rights reserved.
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>