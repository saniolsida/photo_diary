<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>{{post.title}} - 상세보기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .detail-img { max-width: 100%; height: auto; border-radius: 10px; margin-bottom: 20px; }
        .content-area { white-space: pre-wrap; line-height: 1.8; }
    </style>
</head>
<body class="bg-light">
<nav class="navbar navbar-light bg-white shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">📸 Photo Diary</a>
    </div>
</nav>

<div class="container py-4">
    {{#post}}
        <div class="row justify-content-center">
            <div class="col-lg-8 bg-white p-5 shadow-sm rounded">
                <h1 class="fw-bold mb-3">{{title}}</h1>
                <p class="text-muted mb-4">작성자: {{author}} | 작성일: {{createdAt}}</p>

                <img src="{{imageUrl}}" class="detail-img shadow-sm" alt="Post Image">

                <div class="content-area fs-5 mb-5">
                    {{content}}
                </div>

                <hr>
                <div class="d-flex justify-content-between">
                    <a href="/" class="btn btn-secondary">목록으로</a>
                    <div>
                        <a href="/post/edit/{{id}}" class="btn btn-primary me-2">수정하기</a>
                        <a href="/post/delete/{{id}}" class="btn btn-danger" onclick="return confirm('정말 삭제하시겠습니까?')">삭제하기</a>
                    </div>
                </div>
            </div>
        </div>
    {{/post}}
</div>
</body>
</html>