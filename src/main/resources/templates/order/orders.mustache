<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>주문 관리 - Photo Diary</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<nav class="navbar navbar-light bg-white shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold text-primary" href="/">📸 Photo Diary</a>
    </div>
</nav>

<div class="container">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h4 class="mb-0 fw-bold">📦 인쇄 주문 내역</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                <tr>
                    <th>주문 번호</th>
                    <th>배송지</th>
                    <th>포함된 게시글 ID</th> <th>상태</th>
                    <th>주문 일시</th>
                    <th>액션</th>
                </tr>
                </thead>
                <tbody>
                {{#orders}}
                    <tr>
                        <td>#{{id}}</td>
                        <td>
                            <span class="text-muted small">{{shippingAddress}}</span>
                        </td>
                        <td>
                            <span class="text-primary fw-bold">{{displayPostIds}}</span>
                        </td>

                        <td>
                            <span class="badge {{statusColor}}">{{status}}</span>
                        </td>
                        <td>{{orderDate}}</td>
                        <td>
                            {{#isPending}}
                                <a href="/order/process/{{id}}" class="btn btn-sm btn-warning">데이터 처리 시작</a>
                            {{/isPending}}

                            {{#isProcessing}}
                                <div class="d-flex align-items-center">
                                    <div class="spinner-border spinner-border-sm text-success me-2" role="status"></div>
                                    <span class="text-success fw-bold">데이터 패키징 중...</span>

                                    <a href="/order/download/{{id}}" id="autoDownload-{{id}}" class="d-none">숨겨진 다운로드</a>
                                </div>

                                <script>
                                    window.onload = function() {
                                        setTimeout(() => {
                                            const link = document.getElementById('autoDownload-{{id}}');
                                            if (link) {
                                                link.click(); // 숨겨진 링크 클릭
                                                // 다운로드 완료 후 상태 반영을 위해 5초 뒤 새로고침
                                                setTimeout(() => { location.reload(); }, 5000);
                                            }
                                        }, 500);
                                    };
                                </script>
                            {{/isProcessing}}

                            {{#isCompleted}}
                                <span class="badge bg-light text-dark border">
            <i class="bi bi-check-circle-fill text-success"></i> ✅ 완료됨
        </span>
                            {{/isCompleted}}
                        </td>
                    </tr>
                {{/orders}}
                {{^orders}}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">주문 내역이 없습니다.</td>
                    </tr>
                {{/orders}}
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-3 text-end">
        <a href="/" class="btn btn-link text-secondary">메인으로 돌아가기</a>
    </div>
</div>
</body>
</html>