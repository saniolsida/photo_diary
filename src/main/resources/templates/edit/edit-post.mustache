<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>기록 수정하기 - Photo Diary</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold text-primary" href="/">
            <i class="bi bi-camera-fill"></i> Photo Diary
        </a>
    </div>
</nav>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>기록 수정하기</h4>
                </div>
                <div class="card-body p-4">
                    {{#post}}
                        <form action="/post/update" method="post">
                            <input type="hidden" name="id" value="{{id}}">
                            <input type="hidden" name="createdAt" value="{{createdAt}}">

                            <div class="mb-3">
                                <label class="form-label">작성자</label>
                                <input type="text" name="author" class="form-control" value="{{author}}" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">제목</label>
                                <input type="text" name="title" class="form-control" value="{{title}}" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">이미지 URL</label>
                                <input type="text" name="imageUrl" class="form-control" value="{{imageUrl}}" required>
                                <div class="form-text">이미지 주소를 입력해 주세요. (Unsplash 등)</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">내용</label>
                                <textarea name="content" class="form-control" rows="8" required>{{content}}</textarea>
                            </div>

                            <hr class="my-4">

                            <div class="d-flex justify-content-between align-items-center">
                                <a href="/post/detail/{{id}}" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle"></i> 취소
                                </a>
                                <div>
                                    <a href="/post/delete/{{id}}" class="btn btn-outline-danger me-2" onclick="return confirm('정말 삭제하시겠습니까?')">
                                        <i class="bi bi-trash"></i> 삭제
                                    </a>
                                    <button type="submit" class="btn btn-primary px-4 fw-bold">
                                        <i class="bi bi-check-lg"></i> 수정 완료
                                    </button>
                                </div>
                            </div>
                        </form>
                    {{/post}}
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>