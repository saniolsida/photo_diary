<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>기록 수정하기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">기록 수정하기</h4>
                </div>
                <div class="card-body">
                    {{#post}}
                        <form action="/post/update" method="post">
                            <input type="hidden" name="id" value="{{id}}">
                            <input type="hidden" name="createdAt" value="{{createdAt}}">

                            <div class="mb-3">
                                <label class="form-label">작성자</label>
                                <input type="text" name="author" class="form-control" value="{{author}}" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">제목</label>
                                <input type="text" name="title" class="form-control" value="{{title}}" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">이미지 URL</label>
                                <input type="text" name="imageUrl" class="form-control" value="{{imageUrl}}" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">내용</label>
                                <textarea name="content" class="form-control" rows="5" required>{{content}}</textarea>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="/" class="btn btn-secondary">취소</a>
                                <div>
                                    <a href="/post/delete/{{id}}" class="btn btn-danger me-2" onclick="return confirm('정말 삭제하시겠습니까?')">삭제</a>
                                    <button type="submit" class="btn btn-success">수정 완료</button>
                                </div>
                            </div>
                        </form>
                    {{/post}}
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>