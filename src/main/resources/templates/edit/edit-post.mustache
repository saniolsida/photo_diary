<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>기록 수정하기 - Photo Diary</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold text-primary" href="/"><i class="bi bi-camera-fill"></i> Photo Diary</a>
    </div>
</nav>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>기록 수정하기</h4>
                </div>
                <div class="card-body p-4">
                    {{#post}} <form action="/post/update" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="id" value="{{id}}">
                        <input type="hidden" name="createdAt" value="{{createdAt}}">

                        <div class="mb-3">
                            <label class="form-label fw-bold">작성자</label>
                            <input type="text" name="author" class="form-control" value="{{author}}" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">제목</label>
                            <input type="text" name="title" class="form-control" value="{{title}}" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">현재 등록된 사진</label>
                            <div class="d-flex flex-wrap gap-2 p-2 bg-light rounded border">
                                {{#images}}
                                    <img src="{{imageUrl}}" class="rounded shadow-sm" style="width: 80px; height: 80px; object-fit: cover;">
                                {{/images}}
                                {{^images}}<small class="text-muted p-2">등록된 사진이 없습니다.</small>{{/images}}
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">사진 변경 (여러 장 가능)</label>
                            <input type="file" name="imageFiles" class="form-control" accept="image/*" multiple>
                            <div class="form-text text-primary small">
                                <i class="bi bi-info-circle"></i> 새 사진을 선택하면 기존 사진은 모두 교체됩니다.
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">태그</label>
                            <input type="hidden" id="existingTag" value="{{tag}}">

                            <select name="tag" id="tagSelect" class="form-select">
                                <option value="">태그 선택 없음</option>
                                <option value="일상">#일상</option>
                                <option value="여행">#여행</option>
                                <option value="맛집">#맛집</option>
                            </select>
                            <div class="form-text">기존 태그: {{#tag}}#{{.}}{{/tag}}{{^tag}}없음{{/tag}}</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">오늘의 기분</label>
                            <div class="d-flex flex-wrap gap-3 p-3 bg-white border rounded">
                                <input type="hidden" id="existingMood" value="{{mood}}">

                                <div class="form-check">
                                    <input class="form-check-input mood-radio" type="radio" name="mood" value="😊" id="mood1">
                                    <label class="form-check-label" for="mood1">😊 행복</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input mood-radio" type="radio" name="mood" value="🤩" id="mood2">
                                    <label class="form-check-label" for="mood2">🤩 신남</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input mood-radio" type="radio" name="mood" value="😴" id="mood3">
                                    <label class="form-check-label" for="mood3">😴 피곤</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input mood-radio" type="radio" name="mood" value="🍕" id="mood4">
                                    <label class="form-check-label" for="mood4">🍕 배부름</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input mood-radio" type="radio" name="mood" value="✈️" id="mood5">
                                    <label class="form-check-label" for="mood5">✈️ 여행</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">내용</label>
                            <textarea name="content" class="form-control" rows="8" required>{{content}}</textarea>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/post/detail/{{id}}" class="btn btn-outline-secondary px-4">취소</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold">수정 완료</button>
                        </div>
                    </form>
                    {{/post}} </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 1. 기분(Mood) 기존 데이터 세팅 (송산님이 이미 가지고 계신 로직과 유사)
        const existingMood = document.getElementById("existingMood").value;
        if (existingMood) {
            const moodRadio = document.querySelector(`.mood-radio[value="${existingMood}"]`);
            if (moodRadio) moodRadio.checked = true;
        }

        // 2. 태그(Tag) 기존 데이터 세팅 (새로 추가할 부분)
        const existingTag = document.getElementById("existingTag").value;
        if (existingTag) {
            const tagSelect = document.getElementById("tagSelect");
            tagSelect.value = existingTag; // 이 한 줄이 핵심입니다!
        }
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>